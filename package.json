{
  "name": "reigns-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/check-syntax.mjs && node scripts/verify-exports.mjs && node scripts/verify-boundaries.mjs && node scripts/verify-anti-rpg.mjs && node scripts/verify-fixtures.mjs",
    "content:validate": "node scripts/content-tool.mjs validate",
    "content:review": "node scripts/content-tool.mjs review",
    "content:convert": "node scripts/content-tool.mjs convert",
    "content:feedback": "node scripts/content-tool.mjs feedback",
    "test:unit": "node --test \"packages/**/*.test.js\"",
    "test:integration": "node --test \"test/**/*.test.js\"",
    "test": "npm run test:unit && npm run test:integration",
    "verify": "npm run build && npm test",
    "ci": "npm run verify"
  },
  "engines": {
    "node": ">=20"
  }
}
