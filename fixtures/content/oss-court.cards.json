  "cards": [
    {
      "id": "gate-audience",
      "text": "At first light, two petitions reach the city gate.",
      "i18n": {
        "zh-Hans": {
          "text": "晨光初起，两份请愿送到城门。",
          "choices": {
            "left": { "label": "听粮仓请愿" },
            "right": { "label": "听边境急报" }
          }
        }
      },
      "weight": 2,
      "choices": [
        {
          "id": "left",
          "label": "Hear the grain plea",
          "effects": {
            "factions": { "gauge1": 6, "gauge3": -4 },
            "tags": { "grainRelief": true },
            "variables": { "openingPetition": "grain" }
          }
        },
        {
          "id": "right",
          "label": "Hear the border plea",
          "effects": {
            "factions": { "gauge2": 6, "gauge3": -3 },
            "tags": { "borderAlert": true },
            "variables": { "openingPetition": "border" }
          }
        }
      ]
    },
    {
      "id": "granary-count",
      "text": "The granary clerks ask whether to release emergency stores.",
      "i18n": {
        "zh-Hans": {
          "text": "粮仓书记询问是否释放应急储粮。",
          "choices": {
            "left": { "label": "打开粮仓" },
            "right": { "label": "审查账册" }
          }
        }
      },
      "weight": 1,
      "requirements": {
        "allTags": ["grainRelief"],
        "variables": { "openingPetition": "grain" },
        "factions": {
          "gauge1": { "min": 55 },
          "gauge3": { "max": 48 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Open the stores",
          "effects": {
            "factions": { "gauge1": 8, "gauge3": -7, "gauge0": 2 },
            "tags": { "granaryOpen": true }
          }
        },
        {
          "id": "right",
          "label": "Audit the ledgers",
          "effects": {
            "factions": { "gauge3": 5, "gauge1": -4 },
            "tags": { "auditLedger": true }
          }
        }
      ]
    },
    {
      "id": "bread-line",
      "text": "A bread line forms before noon, asking who should receive the first loaves.",
      "i18n": {
        "zh-Hans": {
          "text": "午前，领面包的队伍排起，询问第一批面包该给谁。",
          "choices": {
            "left": { "label": "发放配给牌" },
            "right": { "label": "交给行会" }
          }
        }
      },
      "weight": 2,
      "requirements": {
        "allTags": ["granaryOpen"],
        "variables": { "openingPetition": "grain" },
        "factions": {
          "gauge1": { "min": 60 },
          "gauge3": { "max": 42 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Issue ration tokens",
          "effects": {
            "factions": { "gauge1": 4, "gauge3": -4, "gauge0": 1 },
            "tags": { "breadLine": true, "rationTokens": true },
            "variables": { "reliefStyle": "tokens" }
          }
        },
        {
          "id": "right",
          "label": "Let the guilds serve",
          "effects": {
            "factions": { "gauge3": 3, "gauge1": -2, "gauge0": -1 },
            "tags": { "breadLine": true, "guildRelief": true },
            "variables": { "reliefStyle": "guild" }
          }
        }
      ]
    },
    {
      "id": "border-messenger",
      "text": "A rider reports smoke beyond the northern stones.",
      "i18n": {
        "zh-Hans": {
          "text": "骑手报告北方界石外升起烟柱。",
          "choices": {
            "left": { "label": "升起军旗" },
            "right": { "label": "派出使者" }
          }
        }
      },
      "weight": 1,
      "requirements": {
        "allTags": ["borderAlert"],
        "variables": { "openingPetition": "border" },
        "factions": {
          "gauge2": { "min": 55 },
          "gauge3": { "max": 48 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Raise the banner",
          "effects": {
            "factions": { "gauge2": 8, "gauge1": -4, "gauge3": -3 },
            "tags": { "muster": true }
          }
        },
        {
          "id": "right",
          "label": "Send an envoy",
          "effects": {
            "factions": { "gauge0": 3, "gauge3": -4, "gauge2": -2 },
            "tags": { "envoySent": true }
          }
        }
      ]
    },
    {
      "id": "watch-parley",
      "text": "The envoy returns with a quiet border parley before the watch loses patience.",
      "i18n": {
        "zh-Hans": {
          "text": "使者带回边境密谈的机会，而守望队已快失去耐心。",
          "choices": {
            "left": { "label": "接受密谈" },
            "right": { "label": "写巡逻宪令" }
          }
        }
      },
      "weight": 2,
      "requirements": {
        "allTags": ["envoySent"],
        "variables": { "openingPetition": "border" },
        "factions": {
          "gauge2": { "max": 55 },
          "gauge3": { "max": 45 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Accept the parley",
          "effects": {
            "factions": { "gauge0": 4, "gauge2": -3, "gauge1": 2 },
            "tags": { "watchParley": true },
            "variables": { "borderStyle": "parley" }
          }
        },
        {
          "id": "right",
          "label": "Write a patrol charter",
          "effects": {
            "factions": { "gauge2": 3, "gauge3": -3, "gauge1": -1 },
            "tags": { "patrolCharter": true },
            "variables": { "borderStyle": "patrol" }
          }
        }
      ]
    },
    {
      "id": "harbor-contract",
      "text": "Merchants offer a dock contract if the court acts before dusk.",
      "i18n": {
        "zh-Hans": {
          "text": "商人提出码头契约，要求宫廷在黄昏前决定。",
          "choices": {
            "left": { "label": "签署特许" },
            "right": { "label": "推迟特许" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["granaryOpen", "auditLedger", "envoySent", "muster"] },
      "choices": [
        {
          "id": "left",
          "label": "Sign the charter",
          "effects": {
            "factions": { "gauge3": 8, "gauge1": -2 },
            "tags": { "harborTrade": true }
          }
        },
        {
          "id": "right",
          "label": "Delay the charter",
          "effects": {
            "factions": { "gauge1": 3, "gauge3": -4 },
            "tags": { "charterDelayed": true }
          }
        }
      ]
    },
    {
      "id": "chapel-dispute",
      "text": "The chapel asks for a public rite after the morning unrest.",
      "i18n": {
        "zh-Hans": {
          "text": "礼拜堂请求在清晨骚动后举行公开仪式。",
          "choices": {
            "left": { "label": "举行仪式" },
            "right": { "label": "私下处理" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["granaryOpen", "breadLine", "envoySent", "watchParley", "charterDelayed"] },
      "choices": [
        {
          "id": "left",
          "label": "Hold the rite",
          "effects": {
            "factions": { "gauge0": 7, "gauge3": -3, "gauge1": 2 },
            "tags": { "riteHeld": true }
          }
        },
        {
          "id": "right",
          "label": "Keep it private",
          "effects": {
            "factions": { "gauge1": 3, "gauge0": -5 },
            "tags": { "mediated": true }
          }
        }
      ]
    },
    {
      "id": "banner-review",
      "text": "Captains want an answer before they dismiss the watch.",
      "i18n": {
        "zh-Hans": {
          "text": "队长们想在解散守望前得到答复。",
          "choices": {
            "left": { "label": "奖赏守望" },
            "right": { "label": "让其归营" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["muster", "auditLedger", "harborTrade", "watchParley", "patrolCharter"] },
      "choices": [
        {
          "id": "left",
          "label": "Reward the watch",
          "effects": {
            "factions": { "gauge2": 6, "gauge3": -4 },
            "tags": { "watchRewarded": true }
          }
        },
        {
          "id": "right",
          "label": "Send them home",
          "effects": {
            "factions": { "gauge1": 4, "gauge2": -5 },
            "tags": { "watchDismissed": true }
          }
        }
      ]
    },
    {
      "id": "ledger-council",
      "text": "The council asks how much of the day's accounts to reveal.",
      "i18n": {
        "zh-Hans": {
          "text": "议会询问今日账目应公开多少。",
          "choices": {
            "left": { "label": "公开账目" },
            "right": { "label": "封存账目" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["auditLedger", "harborTrade", "riteHeld", "rationTokens", "watchParley", "patrolCharter", "watchRewarded", "watchDismissed"] },
      "choices": [
        {
          "id": "left",
          "label": "Publish the accounts",
          "effects": {
            "factions": { "gauge1": 4, "gauge3": -3, "gauge0": 1 },
            "tags": { "ledgerOpen": true }
          }
        },
        {
          "id": "right",
          "label": "Seal the accounts",
          "effects": {
            "factions": { "gauge3": 6, "gauge1": -4 },
            "tags": { "ledgerSealed": true }
          }
        }
      ]
    },
    {
      "id": "treasury-count",
      "text": "The treasurer counts the cost of the court's morning.",
      "i18n": {
        "zh-Hans": {
          "text": "司库核算宫廷这一上午的代价。",
          "choices": {
            "left": { "label": "拨款修缮" },
            "right": { "label": "保留储备" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["harborTrade", "ledgerOpen", "ledgerSealed"] },
      "choices": [
        {
          "id": "left",
          "label": "Spend on repairs",
          "effects": {
            "factions": { "gauge1": 5, "gauge3": -5, "gauge2": 1 },
            "tags": { "repairsFunded": true }
          }
        },
        {
          "id": "right",
          "label": "Hold reserves",
          "effects": {
            "factions": { "gauge3": 5, "gauge1": -3, "gauge0": -1 },
            "tags": { "reservesHeld": true }
          }
        }
      ]
    },
    {
      "id": "token-riot",
      "text": "By late afternoon, ration tokens pass from hand to hand faster than bread.",
      "i18n": {
        "zh-Hans": {
          "text": "午后，配给牌在人群中流转得比面包还快。",
          "choices": {
            "left": { "label": "开夜间粥棚" },
            "right": { "label": "核查配给牌" }
          }
        }
      },
      "weight": 2,
      "requirements": {
        "allTags": ["rationTokens"],
        "variables": { "reliefStyle": "tokens" },
        "factions": {
          "gauge1": { "min": 62 },
          "gauge3": { "max": 43 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Open night kitchens",
          "effects": {
            "factions": { "gauge1": 5, "gauge3": -5, "gauge0": 2 },
            "tags": { "nightKitchens": true },
            "variables": { "afternoonRelief": "kitchens" }
          }
        },
        {
          "id": "right",
          "label": "Audit the tokens",
          "effects": {
            "factions": { "gauge3": 4, "gauge1": -3, "gauge2": 2 },
            "tags": { "tokenAudit": true },
            "variables": { "afternoonRelief": "audit" }
          }
        }
      ]
    },
    {
      "id": "guild-feast",
      "text": "The guilds turn relief into a public feast and ask whose name should be on the tables.",
      "i18n": {
        "zh-Hans": {
          "text": "行会把救济办成公开宴席，并询问餐桌上该写谁的名字。",
          "choices": {
            "left": { "label": "让行会署名" },
            "right": { "label": "写宫廷欠据" }
          }
        }
      },
      "weight": 2,
      "requirements": {
        "allTags": ["guildRelief"],
        "variables": { "reliefStyle": "guild" },
        "factions": {
          "gauge1": { "min": 58 },
          "gauge3": { "min": 40 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Let guild banners lead",
          "effects": {
            "factions": { "gauge1": 3, "gauge3": 3, "gauge0": -2 },
            "tags": { "guildCompact": true },
            "variables": { "afternoonRelief": "guild-compact" }
          }
        },
        {
          "id": "right",
          "label": "Write court debt notes",
          "effects": {
            "factions": { "gauge3": -5, "gauge1": 2, "gauge0": 1 },
            "tags": { "guildDebt": true },
            "variables": { "afternoonRelief": "debt" }
          }
        }
      ]
    },
    {
      "id": "parley-hostage",
      "text": "The border parley asks for a temporary hostage exchange before dusk.",
      "i18n": {
        "zh-Hans": {
          "text": "边境密谈要求在黄昏前交换临时人质。",
          "choices": {
            "left": { "label": "交换人质" },
            "right": { "label": "公开条款" }
          }
        }
      },
      "weight": 2,
      "requirements": {
        "allTags": ["watchParley"],
        "variables": { "borderStyle": "parley" },
        "factions": {
          "gauge2": { "max": 52 },
          "gauge0": { "min": 54 }
        }
      },
      "choices": [
        {
          "id": "left",
          "label": "Exchange honored hostages",
          "effects": {
            "factions": { "gauge0": 3, "gauge2": -2, "gauge1": 2 },
            "tags": { "peaceOath": true },
            "variables": { "afternoonBorder": "oath" }
          }
        },
        {
          "id": "right",
          "label": "Publish the terms",
