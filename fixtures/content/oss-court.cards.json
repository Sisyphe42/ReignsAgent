{
  "metadata": {
    "title": "Open Court Sample",
    "version": "0.2.0",
    "description": "A complete local test deck for Phase 4 creator, player, diagnostics, and build workflows.",
    "artLicense": "CC BY 3.0",
    "artSource": "Game-icons.net SVG icons from the game-icons/icons repository",
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en", "zh-Hans"]
    },
    "presentation": {
      "schemaVersion": 1,
      "gauges": {
        "gauge0": {
          "label": "Rites",
          "description": "Temple trust and public ceremony."
        },
        "gauge1": {
          "label": "Crowd",
          "description": "How ordinary citizens read the court."
        },
        "gauge2": {
          "label": "Watch"
        },
        "gauge3": {
          "label": "Coin"
        }
      },
      "css": {
        "variables": {
          "--accent": "#d2a94a",
          "--accent-2": "#76a9b8"
        },
        "text": ""
      },
      "html": {},
      "js": {},
      "policy": {
        "allowCssText": false,
        "allowHtml": false,
        "allowJs": false
      }
    },
    "story": {
      "groups": [
        {
          "id": "opening",
          "label": "Opening Audience",
          "type": "chapter",
          "description": "The first audience splits the court into grain or border pressure.",
          "cardIds": ["gate-audience"]
        },
        {
          "id": "grain-branch",
          "label": "Grain Branch",
          "type": "chapter",
          "description": "A relief branch that opens only when the grain choice, route variable, and crowd/coin thresholds line up.",
          "cardIds": ["granary-count", "bread-line", "token-riot", "guild-feast"]
        },
        {
          "id": "border-branch",
          "label": "Border Branch",
          "type": "chapter",
          "description": "A border branch that opens only when the border choice, route variable, and watch/coin thresholds line up.",
          "cardIds": ["border-messenger", "watch-parley", "parley-hostage", "patrol-incident"]
        },
        {
          "id": "afternoon-branch",
          "label": "Afternoon Branches",
          "type": "chapter",
          "description": "Second-wave consequences from relief or border policy.",
          "cardIds": ["river-market", "rumor-house", "harvest-court", "hostage-court", "unrest-court"]
        },
        {
          "id": "closing-council",
          "label": "Closing Council",
          "type": "chapter",
          "description": "The final council turns earlier branches into an ending path.",
          "cardIds": ["midnight-council", "dawn-gate", "morning-procession", "locked-city"]
        },
        {
          "id": "grain-thread",
          "label": "Grain Thread",
          "type": "theme",
          "description": "Civil relief, ledgers, and food politics.",
          "tags": ["grainRelief", "granaryOpen", "auditLedger", "breadLine", "rationTokens", "guildRelief", "nightKitchens", "tokenAudit", "guildCompact", "guildDebt", "harvestOath", "marketTax", "ledgerOpen", "ledgerSealed"]
        },
        {
          "id": "border-thread",
          "label": "Border Thread",
          "type": "theme",
          "description": "Military pressure, envoys, and watch decisions.",
          "tags": ["borderAlert", "muster", "envoySent", "watchParley", "patrolCharter", "peaceOath", "publicTerms", "patrolRestrained", "raidOrdered", "borderOath", "quietPact", "watchRewarded", "watchDismissed"]
        },
        {
          "id": "unrest-thread",
          "label": "Unrest Thread",
          "type": "theme",
          "description": "Rumor, scarcity, curfew, and public confidence.",
          "tags": ["rumorSpread", "crowdAppeased", "watchCurfew", "councilReady", "endingMercy", "endingAuthority"]
        },
        {
          "id": "gate-endings",
          "label": "Dawn Gate Endings",
          "type": "ending",
          "description": "The closing gate decision produced by the final card.",
          "tags": ["gateOpened", "gateClosed", "endingMercy", "endingAuthority"]
        }
      ]
    }
  },
