  "cards": [
    {
      "id": "gate-audience",
      "text": "At first light, two petitions reach the city gate.",
      "i18n": {
        "zh-Hans": {
          "text": "晨光初起，两份请愿送到城门。",
          "choices": {
            "left": { "label": "听粮仓请愿" },
            "right": { "label": "听边境急报" }
          }
        }
      },
      "weight": 2,
      "choices": [
        {
          "id": "left",
          "label": "Hear the grain plea",
          "effects": {
            "factions": { "people": 6, "treasury": -4 },
            "tags": { "grainRelief": true },
            "variables": { "openingPetition": "grain" }
          }
        },
        {
          "id": "right",
          "label": "Hear the border plea",
          "effects": {
            "factions": { "military": 6, "treasury": -3 },
            "tags": { "borderAlert": true },
            "variables": { "openingPetition": "border" }
          }
        }
      ]
    },
    {
      "id": "granary-count",
      "text": "The granary clerks ask whether to release emergency stores.",
      "i18n": {
        "zh-Hans": {
          "text": "粮仓书记询问是否释放应急储粮。",
          "choices": {
            "left": { "label": "打开粮仓" },
            "right": { "label": "审查账册" }
          }
        }
      },
      "weight": 1,
      "requirements": { "allTags": ["grainRelief"] },
      "choices": [
        {
          "id": "left",
          "label": "Open the stores",
          "effects": {
            "factions": { "people": 8, "treasury": -7, "faith": 2 },
            "tags": { "granaryOpen": true }
          }
        },
        {
          "id": "right",
          "label": "Audit the ledgers",
          "effects": {
            "factions": { "treasury": 5, "people": -4 },
            "tags": { "auditLedger": true }
          }
        }
      ]
    },
    {
      "id": "border-messenger",
      "text": "A rider reports smoke beyond the northern stones.",
      "i18n": {
        "zh-Hans": {
          "text": "骑手报告北方界石外升起烟柱。",
          "choices": {
            "left": { "label": "升起军旗" },
            "right": { "label": "派出使者" }
          }
        }
      },
      "weight": 1,
      "requirements": { "allTags": ["borderAlert"] },
      "choices": [
        {
          "id": "left",
          "label": "Raise the banner",
          "effects": {
            "factions": { "military": 8, "people": -4, "treasury": -3 },
            "tags": { "muster": true }
          }
        },
        {
          "id": "right",
          "label": "Send an envoy",
          "effects": {
            "factions": { "faith": 3, "treasury": -4, "military": -2 },
            "tags": { "envoySent": true }
          }
        }
      ]
    },
    {
      "id": "harbor-contract",
      "text": "Merchants offer a dock contract if the court acts before dusk.",
      "i18n": {
        "zh-Hans": {
          "text": "商人提出码头契约，要求宫廷在黄昏前决定。",
          "choices": {
            "left": { "label": "签署特许" },
            "right": { "label": "推迟特许" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["granaryOpen", "auditLedger", "envoySent", "muster"] },
      "choices": [
        {
          "id": "left",
          "label": "Sign the charter",
          "effects": {
            "factions": { "treasury": 8, "people": -2 },
            "tags": { "harborTrade": true }
          }
        },
        {
          "id": "right",
          "label": "Delay the charter",
          "effects": {
            "factions": { "people": 3, "treasury": -4 },
            "tags": { "charterDelayed": true }
          }
        }
      ]
    },
    {
      "id": "chapel-dispute",
      "text": "The chapel asks for a public rite after the morning unrest.",
      "i18n": {
        "zh-Hans": {
          "text": "礼拜堂请求在清晨骚动后举行公开仪式。",
          "choices": {
            "left": { "label": "举行仪式" },
            "right": { "label": "私下处理" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["granaryOpen", "envoySent", "charterDelayed"] },
      "choices": [
        {
          "id": "left",
          "label": "Hold the rite",
          "effects": {
            "factions": { "faith": 7, "treasury": -3, "people": 2 },
            "tags": { "riteHeld": true }
          }
        },
        {
          "id": "right",
          "label": "Keep it private",
          "effects": {
            "factions": { "people": 3, "faith": -5 },
            "tags": { "mediated": true }
          }
        }
      ]
    },
    {
      "id": "banner-review",
      "text": "Captains want an answer before they dismiss the watch.",
      "i18n": {
        "zh-Hans": {
          "text": "队长们想在解散守望前得到答复。",
          "choices": {
            "left": { "label": "奖赏守望" },
            "right": { "label": "让其归营" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["muster", "auditLedger", "harborTrade"] },
      "choices": [
        {
          "id": "left",
          "label": "Reward the watch",
          "effects": {
            "factions": { "military": 6, "treasury": -4 },
            "tags": { "watchRewarded": true }
          }
        },
        {
          "id": "right",
          "label": "Send them home",
          "effects": {
            "factions": { "people": 4, "military": -5 },
            "tags": { "watchDismissed": true }
          }
        }
      ]
    },
    {
      "id": "ledger-council",
      "text": "The council asks how much of the day's accounts to reveal.",
      "i18n": {
        "zh-Hans": {
          "text": "议会询问今日账目应公开多少。",
          "choices": {
            "left": { "label": "公开账目" },
            "right": { "label": "封存账目" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["auditLedger", "harborTrade", "riteHeld", "watchRewarded", "watchDismissed"] },
      "choices": [
        {
          "id": "left",
          "label": "Publish the accounts",
          "effects": {
            "factions": { "people": 4, "treasury": -3, "faith": 1 },
            "tags": { "ledgerOpen": true }
          }
        },
        {
          "id": "right",
          "label": "Seal the accounts",
          "effects": {
            "factions": { "treasury": 6, "people": -4 },
            "tags": { "ledgerSealed": true }
          }
        }
      ]
    },
    {
      "id": "treasury-count",
      "text": "The treasurer counts the cost of the court's morning.",
      "i18n": {
        "zh-Hans": {
          "text": "司库核算宫廷这一上午的代价。",
          "choices": {
            "left": { "label": "拨款修缮" },
            "right": { "label": "保留储备" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["harborTrade", "ledgerOpen", "ledgerSealed"] },
      "choices": [
        {
          "id": "left",
          "label": "Spend on repairs",
          "effects": {
            "factions": { "people": 5, "treasury": -5, "military": 1 },
            "tags": { "repairsFunded": true }
          }
        },
        {
          "id": "right",
          "label": "Hold reserves",
          "effects": {
            "factions": { "treasury": 5, "people": -3, "faith": -1 },
            "tags": { "reservesHeld": true }
          }
        }
      ]
    },
    {
      "id": "dawn-gate",
      "text": "By sunset, the gate guard asks what story the city should hear.",
      "i18n": {
        "zh-Hans": {
          "text": "日落时，城门卫兵询问城市该听见怎样的说法。",
          "choices": {
            "left": { "label": "打开城门" },
            "right": { "label": "关闭城门" }
          }
        }
      },
      "weight": 1,
      "requirements": { "anyTags": ["repairsFunded", "reservesHeld", "mediated", "watchDismissed"] },
      "choices": [
        {
          "id": "left",
          "label": "Open the gate",
          "effects": {
            "factions": { "people": 5, "faith": 2, "military": -2 },
            "tags": { "gateOpened": true }
          }
        },
        {
          "id": "right",
          "label": "Close the gate",
          "effects": {
            "factions": { "military": 5, "treasury": 2, "people": -3 },
            "tags": { "gateClosed": true }
          }
        }
      ]
    }
  ]
}
