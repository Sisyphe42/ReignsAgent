{
  "metadata": {
    "title": "Open Court Sample",
    "version": "0.2.0",
    "description": "A complete local test deck for Phase 4 creator, player, diagnostics, and build workflows.",
    "artLicense": "CC BY 3.0",
    "artSource": "Game-icons.net SVG icons from the game-icons/icons repository",
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": ["en", "zh-Hans"]
    },
    "presentation": {
      "schemaVersion": 1,
      "gauges": {
        "faith": {
          "label": "Rites",
          "description": "Temple trust and public ceremony."
        },
        "people": {
          "label": "Crowd",
          "description": "How ordinary citizens read the court."
        },
        "military": {
          "label": "Watch"
        },
        "treasury": {
          "label": "Coin"
        }
      },
      "css": {
        "variables": {
          "--accent": "#d2a94a",
          "--accent-2": "#76a9b8"
        },
        "text": ""
      },
      "html": {},
      "js": {},
      "policy": {
        "allowCssText": false,
        "allowHtml": false,
        "allowJs": false
      }
    },
    "story": {
      "groups": [
        {
          "id": "opening",
          "label": "Opening Audience",
          "type": "chapter",
          "description": "The first audience splits the court into grain or border pressure.",
          "cardIds": ["gate-audience"]
        },
        {
          "id": "grain-thread",
          "label": "Grain Thread",
          "type": "theme",
          "description": "Civil relief, ledgers, and food politics.",
          "tags": ["grainRelief", "granaryOpen", "auditLedger", "ledgerOpen", "ledgerSealed"]
        },
        {
          "id": "border-thread",
          "label": "Border Thread",
          "type": "theme",
          "description": "Military pressure, envoys, and watch decisions.",
          "tags": ["borderAlert", "muster", "envoySent", "watchRewarded", "watchDismissed"]
        },
        {
          "id": "gate-endings",
          "label": "Dawn Gate Endings",
          "type": "ending",
          "description": "The closing gate decision produced by the final card.",
          "tags": ["gateOpened", "gateClosed"]
        }
      ]
    }
  },
  "assets": [
    {
      "id": "art-attribution",
      "uri": "assets/sample/ATTRIBUTION.md",
      "title": "Open Court art attribution",
      "sourceUrl": "https://github.com/game-icons/icons",
      "license": "CC BY 3.0",
      "attribution": "Sample art attribution for Game-icons.net SVG assets"
    },
    {
