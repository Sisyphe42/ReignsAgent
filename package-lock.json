{
  "name": "reigns-agent",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "reigns-agent",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@reigns-agent/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@reigns-agent/pipeline": {
      "resolved": "packages/pipeline",
      "link": true
    },
    "node_modules/@reigns-agent/reviewer": {
      "resolved": "packages/reviewer",
      "link": true
    },
    "packages/core": {
      "name": "@reigns-agent/core",
      "version": "0.1.0"
    },
    "packages/pipeline": {
      "name": "@reigns-agent/pipeline",
      "version": "0.1.0"
    },
    "packages/reviewer": {
      "name": "@reigns-agent/reviewer",
      "version": "0.1.0"
    }
  }
}
